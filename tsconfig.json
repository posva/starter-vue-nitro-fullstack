{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "nitro/tsconfig",
  "compilerOptions": {
    "rootDir": ".",
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
  "vueCompilerOptions": {
    "plugins": [
      "vue-router/volar/sfc-route-blocks",
      "vue-router/volar/sfc-typed-router"
    ]
  }
}
