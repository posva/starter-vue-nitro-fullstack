  "type": "module",
  "imports": {
    "#shared/*": "./shared/*.ts"
  },
  "scripts": {
    "build": "vite build",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "dev": "portless vue-nitro vite dev",
    "dev:inspect": "NITRO_DEV_RUNNER=node-process NODE_OPTIONS=--inspect=0 vite dev",
