    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "typecheck": "pnpm run '/^typecheck:.+$/'",
    "typecheck:app": "vue-tsc -p tsconfig.app.json",
    "typecheck:server": "tsgo -p tsconfig.server.json"
  },
