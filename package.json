    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/tsconfig": "^0.9.1",
    "beasties": "^0.4.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "nitro": "latest",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-plugin-posva": "^0.0.2",
